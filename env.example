# Copy this file to `.env` and fill in real values.
# Never commit `.env` (it contains secrets).
#
# The service reads:
# - Telegram + provider selection from environment variables
# - Service/strategy behavior from `config/config.yaml`
#
# See also: `docs/PROJECT_SUMMARY.md` and `docs/CONFIGURATION_MAP.md`

# --- IBKR Gateway connectivity ---
# Host where IBKR Gateway is running (usually localhost)
IBKR_HOST=127.0.0.1
# API port (4002 for Gateway, 7497 for TWS)
IBKR_PORT=4002
# Client IDs for trading and data connections (must be unique per connection)
# Default per market: NQ=10/11, ES=20/21, GC=30/31
IBKR_CLIENT_ID=10
IBKR_DATA_CLIENT_ID=11

# --- IBKR Gateway installation path ---
# Path to your IBKR Gateway + IBC installation directory.
# If not set, defaults to repo-local `ibkr/` directory.
# Recommended: Use an external path like /opt/ibkr or ~/ibkr
#
# The directory should contain:
#   - Jts/          (Gateway installation)
#   - ibc/          (IBC controller)
#
# Example installations:
#   PEARLALGO_IBKR_HOME=/opt/ibkr          # System-wide install
#   PEARLALGO_IBKR_HOME=/home/user/ibkr    # User-local install
#
# To install Gateway + IBC to this location:
#   ./scripts/gateway/gateway.sh install
#   ./scripts/gateway/gateway.sh setup
#
# PEARLALGO_IBKR_HOME=/opt/ibkr

# --- Telegram ---
# Format: <bot_id>:<token>
TELEGRAM_BOT_TOKEN=123456789:REPLACE_WITH_REAL_TOKEN
# Numeric chat id (e.g., 123456789)
TELEGRAM_CHAT_ID=123456789

# --- Data provider selection ---
PEARLALGO_DATA_PROVIDER=ibkr

# --- IBKR Gateway install location (optional) ---
# PEARLALGO_IBKR_HOME=/opt/ibkr

# --- Logging (optional, for systemd/journald) ---
# Uncomment to override log level (default: INFO)
# PEARLALGO_LOG_LEVEL=INFO

# Uncomment to emit JSON logs to stdout (useful for log aggregation)
# PEARLALGO_LOG_JSON=false

# Uncomment to include extra={...} context in text log lines
# PEARLALGO_LOG_EXTRA=false

# --- LLM / AI Integration (optional) ---
# Used by pearl_ai/ module for CLI and web app AI features.
# Note: AI chat features have been removed from Telegram; use CLI/web app instead.

# Claude API (Anthropic) - for deep analysis
# Get your API key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API - for embeddings and fallback
# Get your API key from https://platform.openai.com/
# OPENAI_API_KEY=sk-...

# Local LLM (Ollama) - for quick responses
# OLLAMA_HOST=http://localhost:11434
# PEARL_OLLAMA_MODEL=llama3.1:8b

# --- Live Main Chart + Telegram Mini App (optional) ---
# URL that the service/handler will screenshot for the Telegram dashboard image.
# PEARL_LIVE_CHART_URL=http://localhost:3001
#
# Public HTTPS URL for the in-Telegram Mini App “📈 Live” button (BotFather requires HTTPS).
# PEARL_MINI_APP_URL=https://your-live-chart.example.com
#
# CORS origins for `scripts/live-chart/api_server.py` (comma-separated).
# PEARL_LIVE_CHART_ORIGINS=https://your-live-chart.example.com
