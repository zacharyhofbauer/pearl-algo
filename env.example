# Copy this file to `.env` and fill in real values.
# Never commit `.env` (it contains secrets).
#
# The service reads:
# - Provider selection from environment variables
# - Service/strategy behavior from `config/live/tradovate_paper.yaml`
#
# See also: `docs/START_HERE.md` and `docs/PATH_TRUTH_TABLE.md`

# --- IBKR Gateway connectivity (data only for MNQ/Tradovate agent) ---
# Host where IBKR Gateway is running (usually localhost)
IBKR_HOST=127.0.0.1
# API port: must match Gateway's API port (4001 is the configured default)
IBKR_PORT=4001
# Optional IBC command server port for warm restarts (avoids cold restarts when possible)
# IBKR_COMMAND_PORT=7462
# Optional: set these so IBC can auto-login and you get fewer login/2FA prompts.
# Then run: ./scripts/gateway/gateway.sh reduce-login-prompts
# IBKR_USERNAME=your_ibkr_username
# IBKR_PASSWORD=your_ibkr_password
# Client IDs: Tradovate Paper agent uses 50/51 (set by tv_paper_eval.sh). For other agents use unique IDs.
IBKR_CLIENT_ID=10
IBKR_DATA_CLIENT_ID=11

# --- IBKR Gateway installation path ---
# Path to your IBKR Gateway + IBC installation directory.
# If not set, defaults to repo-local `ibkr/` directory.
# Recommended: Use an external path like /opt/ibkr or ~/ibkr
#
# The directory should contain:
#   - Jts/          (Gateway installation)
#   - ibc/          (IBC controller)
#
# Example installations:
#   PEARLALGO_IBKR_HOME=/opt/ibkr          # System-wide install
#   PEARLALGO_IBKR_HOME=/home/user/ibkr    # User-local install
#
# To install Gateway + IBC to this location:
#   ./scripts/gateway/gateway.sh install
#   ./scripts/gateway/gateway.sh setup
#
# PEARLALGO_IBKR_HOME=/opt/ibkr

# --- Tradovate (paper/live execution) ---
# Required for Tradovate Paper execution
# Prefer storing in ~/.config/pearlalgo/secrets.env (never commit).
# TRADOVATE_USERNAME=your_username
# TRADOVATE_PASSWORD=your_password
# TRADOVATE_CID=your_app_id
# TRADOVATE_SEC=your_app_secret
# TRADOVATE_ENV=demo
# TRADOVATE_ACCOUNT_NAME=DEMO1234567

# --- Data provider selection ---
PEARLALGO_DATA_PROVIDER=ibkr

# --- IBKR Gateway install location (optional) ---
# PEARLALGO_IBKR_HOME=/opt/ibkr

# --- Logging (optional, for systemd/journald) ---
# Uncomment to override log level (default: INFO)
# PEARLALGO_LOG_LEVEL=INFO

# Uncomment to emit JSON logs to stdout (useful for log aggregation)
# PEARLALGO_LOG_JSON=false

# Uncomment to include extra={...} context in text log lines
# PEARLALGO_LOG_EXTRA=false

# --- LLM / AI Integration (optional) ---
# Used by the Pearl AI CLI/web API integration.
# Used by the Pearl AI web API integration.

# Claude API (Anthropic) - for deep analysis
# Get your API key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API - for embeddings and fallback
# Get your API key from https://platform.openai.com/
# OPENAI_API_KEY=sk-...

# Local LLM (Ollama) - for quick responses
# OLLAMA_HOST=http://localhost:11434
# PEARL_OLLAMA_MODEL=llama3.1:8b

# Enable Pearl AI API endpoints on the Web App API server (optional)
# This exposes /api/pearl/* (chat, stream, metrics) from scripts/pearlalgo_web_app/api_server.py
# PEARL_AI_API_ENABLED=true

# --- Web App Access Gate (recommended when sharing a public link) ---
# Enables a simple passcode page on the Next.js dashboard.
# Set these in your local secrets file (preferred) or local .env (never commit).
#
# PEARL_WEBAPP_AUTH_ENABLED=true
# PEARL_WEBAPP_PASSCODE=change-me

# --- API Server Authentication (optional but recommended) ---
# API key authentication for /api/* endpoints (including audit endpoints).
# If not set, API endpoints are unauthenticated (not recommended for production).
#
# PEARL_API_AUTH_ENABLED=true
# PEARL_API_KEY=your-secret-api-key-here
# PEARL_API_KEY_FILE=/path/to/api-keys.txt  # Alternative: one key per line in a file

# --- Operator Passphrase (required for critical write actions) ---
# Required for mutating/operator endpoints such as /api/kill-switch,
# /api/close-all-trades, /api/close-trade, and /api/config.
# Browser/API keys are read-only and cannot authorize these actions.
# Set this in your local secrets file (preferred) or local .env (never commit).
#
# PEARL_OPERATOR_PASSPHRASE=your-secure-passphrase-here
# PEARL_OPERATOR_PHRASE=your-secure-passphrase-here  # Alternative name
