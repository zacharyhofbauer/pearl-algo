# Copy this file to `.env` and fill in real values.
# Never commit `.env` (it contains secrets).
#
# The service reads:
# - Telegram + provider selection from environment variables
# - Service/strategy behavior from `config/config.yaml`
#
# See also: `docs/PROJECT_SUMMARY.md` and `docs/CONFIGURATION_MAP.md`

# --- IBKR Gateway connectivity ---
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=10
IBKR_DATA_CLIENT_ID=11

# --- Telegram ---
# Format: <bot_id>:<token>
TELEGRAM_BOT_TOKEN=123456789:REPLACE_WITH_REAL_TOKEN
# Numeric chat id (e.g., 123456789)
TELEGRAM_CHAT_ID=123456789

# --- Data provider selection ---
PEARLALGO_DATA_PROVIDER=ibkr

# --- Logging (optional, for systemd/journald) ---
# Uncomment to override log level (default: INFO)
# PEARLALGO_LOG_LEVEL=INFO

# Uncomment to emit JSON logs to stdout (useful for log aggregation)
# PEARLALGO_LOG_JSON=false

# Uncomment to include extra={...} context in text log lines
# PEARLALGO_LOG_EXTRA=false

# --- LLM / Claude integration (optional, for /ai_patch command) ---
# Get your API key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: max tokens for response (default: 4096)
# ANTHROPIC_MAX_TOKENS=4096

# Optional: request timeout in seconds (default: 120)
# ANTHROPIC_TIMEOUT=120

