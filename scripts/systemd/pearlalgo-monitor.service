[Unit]
Description=PearlAlgo Health Monitor
After=network.target

[Service]
Type=oneshot
User=pearl
Group=pearl
WorkingDirectory=/home/pearl/PearlAlgoProject
Environment="PATH=/home/pearl/PearlAlgoProject/.venv/bin:/usr/local/bin:/usr/bin:/bin"
EnvironmentFile=/home/pearl/PearlAlgoProject/.env
ExecStart=/home/pearl/PearlAlgoProject/.venv/bin/python scripts/monitoring/monitor.py --market NQ --telegram
