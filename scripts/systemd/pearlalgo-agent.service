[Unit]
Description=PearlAlgo Market Agent - Tradovate Paper
After=network.target ibkr-gateway.service
Wants=ibkr-gateway.service

[Service]
Type=simple
User=pearlalgo
Group=pearlalgo
WorkingDirectory=/home/pearlalgo/PearlAlgoWorkspace
Environment="PATH=/home/pearlalgo/PearlAlgoWorkspace/.venv/bin:/usr/local/bin:/usr/bin:/bin"
EnvironmentFile=/home/pearlalgo/PearlAlgoWorkspace/.env
EnvironmentFile=-/home/pearlalgo/.config/pearlalgo/secrets.env
ExecStart=/home/pearlalgo/PearlAlgoWorkspace/.venv/bin/python -m pearlalgo.market_agent.main --config config/accounts/tradovate_paper.yaml --data-dir data/tradovate/paper
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
