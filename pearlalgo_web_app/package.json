{
  "name": "pearlalgo-web-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:fresh": "rm -rf .next && next dev -p 3001",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "rm -rf .next node_modules/.cache",
    "restart": "pkill -f 'next dev' 2>/dev/null; sleep 1; npm run dev"
  },
  "dependencies": {
    "lightweight-charts": "^4.1.0",
    "next": "14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "sharp": "^0.34.5",
    "typescript": "^5"
  }
}
