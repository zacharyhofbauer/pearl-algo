//@version=5
indicator("Volume", shorttitle="Vol", overlay=false)

// Volume indicator - displays volume bars
// Generic public domain implementation

show_volume = input.bool(true, title="Show Volume")
volume_ma_length = input.int(20, title="Volume MA Length", minval=1)

// Calculate volume
vol = volume
vol_ma = ta.sma(vol, volume_ma_length)

// Plot volume
plot(show_volume ? vol : na, title="Volume", color=close >= open ? color.new(color.green, 0) : color.new(color.red, 0), style=plot.style_columns)
plot(show_volume ? vol_ma : na, title="Volume MA", color=color.new(color.blue, 0), linewidth=1)

// Background color based on volume vs average
bgcolor(vol > vol_ma ? color.new(color.green, 95) : color.new(color.red, 95), title="Volume vs MA")
