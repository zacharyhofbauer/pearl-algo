# ============================================
# PearlAlgo Trading System - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# nano .env
# ============================================

# ============================================
# IBKR Configuration (Required for IBKR trading)
# ============================================
# IBKR Gateway/TWS connection settings
# Default: IB Gateway paper trading port (4002)
# TWS paper: 7497, TWS live: 7496, Gateway live: 4001
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=10
IBKR_DATA_CLIENT_ID=11

# ============================================
# Trading Mode Configuration
# ============================================
# Profile: paper, live, backtest, or dummy
# START WITH PAPER MODE for safety!
PEARLALGO_PROFILE=paper

# Allow live trading (must be true for live profile)
PEARLALGO_ALLOW_LIVE_TRADING=false

# Starting balance for paper/live trading
LIVE_STARTING_BALANCE=50000.0

# Dummy mode: Enable explicit dummy data fallback
# When false and IBKR unavailable, system will raise error instead of silent fallback
PEARLALGO_DUMMY_MODE=false

# ============================================
# LLM API Keys (Optional - for agent reasoning)
# ============================================
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ============================================
# Data Provider API Keys (Optional)
# ============================================
# POLYGON_API_KEY=your_polygon_key_here

# ============================================
# Alerting (Optional)
# ============================================
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id
# DISCORD_WEBHOOK_URL=your_discord_webhook_url
